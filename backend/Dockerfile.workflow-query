FROM golang:1.25.10-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
ARG VERSION=dev
ARG REVISION=unknown
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w -X main.version=${VERSION} -X main.revision=${REVISION}" -o workflow-query backend/services/workflow-query/cmd/server/main.go

FROM alpine:3.22

ARG VERSION=dev
ARG REVISION=unknown

WORKDIR /app

RUN addgroup -S flowgo && adduser -S -G flowgo flowgo
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/workflow-query .
USER flowgo

EXPOSE 8081

LABEL org.opencontainers.image.title="FlowGo Query Service" \
      org.opencontainers.image.description="Read/query API service for FlowGo" \
      org.opencontainers.image.source="https://github.com/azizAltaleb/FlowGo" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${REVISION}"

CMD ["./workflow-query"]
