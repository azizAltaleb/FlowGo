# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=workflow_db
POSTGRES_PORT=5432

# Elasticsearch Configuration
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Kafka Configuration
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:29092,PLAINTEXT_HOST://0.0.0.0:9092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1

# Application Configuration
SERVER_ADDR=0.0.0.0:8080
QUERY_SERVER_ADDR=0.0.0.0:8081
LOG_LEVEL=info

# Security Defaults (OIDC/Auth)
# For local/CI interoperability these defaults are permissive.
# Harden for production deployments.
AUTH_ENFORCE_AUDIENCE=false
AUTH_ALLOW_INSECURE_ISSUER=true

# IAM / OIDC Configuration (ZITADEL example)
# Set issuer URLs to your ZITADEL tenant (or any OIDC provider).
AUTH_ISSUER_INTERNAL_URL=
AUTH_ISSUER_PUBLIC_URL=
AUTH_CLIENT_ID=workflow-backend
AUTH_TOKEN_MODE=jwt
# Example (ZITADEL):
# AUTH_ISSUER_INTERNAL_URL=https://<your-zitadel-domain>
# AUTH_ISSUER_PUBLIC_URL=https://<your-zitadel-domain>
# Required only when AUTH_TOKEN_MODE=introspection
AUTH_INTROSPECTION_URL=
AUTH_INTROSPECTION_CLIENT_ID=
AUTH_INTROSPECTION_CLIENT_SECRET=
AUTH_INTROSPECTION_AUTH_METHOD=basic
# Optional claim mapping overrides
AUTH_CLAIM_SUBJECT_PATH=sub
AUTH_CLAIM_ROLES_PATH=roles,realm_access.roles,groups
AUTH_CLAIM_SCOPES_PATH=scope,scp
AUTH_CLAIM_TENANT_PATH=tenant_id
AUTH_CLAIM_EMAIL_PATH=email
AUTH_CLAIM_NAME_PATH=name

# Optional: OIDC token bootstrap inputs for auth-aware smoke scripts.
OIDC_TOKEN_URL=
OIDC_CLIENT_ID=
OIDC_GRANT_TYPE=password
OIDC_SCOPE=openid profile email
OIDC_USERNAME=
OIDC_PASSWORD=
OIDC_CLIENT_SECRET=
# Example:
# OIDC_TOKEN_URL=https://<your-zitadel-domain>/oauth/v2/token

# Frontend Configuration
VITE_API_URL=http://localhost:9100/api
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=workflow-frontend
# Runtime frontend auth overrides (preferred for IAM switching without rebuild)
FRONTEND_AUTH_OIDC_AUTHORITY=
FRONTEND_AUTH_OIDC_CLIENT_ID=
# Example:
# VITE_OIDC_AUTHORITY=https://<your-zitadel-domain>

# Observability (lightweight Jaeger)
JAEGER_UI_PORT=16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
FRONTEND_PORT=9100
